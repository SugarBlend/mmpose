# S3 MinIO
# service credentials for working with object storage
MINIO_GLOBAL_HOST=localhost
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_DEFAULT_BUCKET=datasets

# Label Studio
# service credentials for working with annotations
LABEL_STUDIO_USERNAME=
LABEL_STUDIO_PASSWORD=
LABEL_STUDIO_URL="http://host.docker.internal:8081"
# personal token for retrieving a completed annotation
LABEL_STUDIO_API_KEY=
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# MLBackend Label Studio
# The default configuration and weights used for pose detection and evaluation are specified and are used
# exclusively by the auto labeling service.
MMPOSE_CHECKPOINT="/app/models/mmpose/rtmpose-x_simcc-body7_pt-body7-halpe26_700e-384x288-7fb6e239_20230606.pth"
MMPOSE_CONFIG="/app/models/mmpose/rtmpose-x_8xb256-700e_body8-halpe26-384x288.py"
#MMPOSE_CHECKPOINT="/app/models/mmpose/rtmw-x_simcc-cocktail14_pt-ucoco_270e-384x288-f840f204_20231122.pth"
#MMPOSE_CONFIG="/app/models/mmpose/rtmw-x_8xb320-270e_cocktail14-384x288.py"
#MMPOSE_CHECKPOINT="/app/models/sapiens/sapiens_0.3b_coco_wholebody_best_coco_wholebody_AP_620.pth"
#MMPOSE_CONFIG="/app/models/sapiens/sapiens_0.3b-210e_coco_wholebody-1024x768.py"
YOLO_MODEL="/app/models/yolo/yolov8m.pt"
DEVICE="cuda:0"
